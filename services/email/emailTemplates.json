  "html-content": "<!doctype html><html lang='en'><head><meta charset='utf-8' /><meta name='viewport' content='width=device-width,initial-scale=1' /><title>Verify your email</title><style>:root{--bg:#f7fafc;--card:#ffffff;--accent:#0ea5a3;--muted:#64748b;--text:#0f172a}body{margin:0;background:var(--bg);font-family:Inter,system-ui,Roboto,Arial;color:var(--text);padding:32px}.wrap{max-width:680px;margin:0 auto}.card{background:var(--card);border-radius:14px;box-shadow:0 12px 36px rgba(2,6,23,0.06);padding:30px;border:1px solid rgba(2,6,23,0.04)}.logo{display:block;margin:0 auto 16px;max-width:140px}.h1{font-size:20px;text-align:center;margin-bottom:8px}.lead{color:var(--muted);text-align:center;margin-bottom:16px}.otp{display:block;margin:14px auto;padding:14px 20px;border-radius:12px;background:#f3f6f5;border:1px dashed rgba(15,23,42,0.06);font-weight:800;letter-spacing:4px;font-size:20px;width:max-content}.muted{font-size:13px;color:var(--muted);text-align:center}footer{padding:18px;text-align:center;font-size:13px;color:var(--muted)}@media(max-width:520px){.card{padding:20px}}</style></head><body><div class='wrap'><div class='card' role='article'><img class='logo' src='<companyLogo>' alt='<companyName> logo' /><h1 class='h1'>Verify your email</h1><p class='lead'>Hi <userName>,<br/>Use the verification code below to complete your signup for <strong><companyName></strong>. This code will expire in <strong><expiryMinutes> minutes</strong>.</p><div class='otp'><verificationCode></div><p class='muted'>If you did not request this, you can safely ignore this email.</p><hr style='border:none;border-top:1px solid rgba(2,6,23,0.04);margin:18px 0' /><p style='margin:0;font-size:14px'>Thanks,<br/>Team <strong><companyName></strong></p></div><footer>This is an automated message — please do not reply.</footer></div></body></html>"
