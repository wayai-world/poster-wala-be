  },
  "html-content": "<!doctype html><html lang='en'><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title>Student Account Created</title><style>:root{--bg:#f7fafc;--card:#ffffff;--muted:#6b7280;--text:#0f172a;--accent:#0ea5a3}body{margin:0;background:var(--bg);font-family:Inter,system-ui,Roboto,Arial;color:var(--text);padding:32px}.wrap{max-width:680px;margin:0 auto}.card{background:var(--card);border-radius:14px;box-shadow:0 10px 30px rgba(2,6,23,.06);border:1px solid rgba(2,6,23,.04)}.inner{padding:34px;text-align:center}.logo{max-width:140px;margin:0 auto 14px;display:block}.h1{font-size:22px;margin:8px 0;font-weight:700}.lead{color:var(--muted);margin:8px 0 18px}.credentials{background:#f3f6f5;border:1px dashed rgba(15,23,42,.06);border-radius:10px;padding:16px;margin:18px 0}.credentials p{margin:6px 0;font-weight:600}.btn{display:inline-block;margin-top:18px;padding:12px 22px;border-radius:10px;background:var(--accent);color:#fff;text-decoration:none;font-weight:700}.muted{font-size:13px;color:var(--muted)}@media(max-width:520px){.inner{padding:20px}}</style></head><body><div class='wrap'><div class='card'><div class='inner'><img class='logo' src='<companyLogo>' alt='<companyName> logo'/><h1 class='h1'>Welcome to <companyName></h1><p class='lead'>Hi <studentName>, your student account has been created. Use the credentials below to log in.</p><div class='credentials'><p><strong>Email:</strong> <studentEmail></p><p><strong>Temporary password:</strong> <temporaryPassword></p></div><a class='btn' href='<loginUrl>'>Go to Login</a><p class='muted' style='margin-top:18px'>Please change your password after first login for security.</p></div></div></div></body></html>"
},

