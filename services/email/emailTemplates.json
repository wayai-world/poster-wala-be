  "html-content": "<!doctype html><html lang='en'><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title>Profile update verification</title><style>:root{--bg:#f7fafc;--card:#ffffff;--muted:#6b7280;--text:#0f172a;--accent:#0ea5a3}body{margin:0;background:var(--bg);font-family:Inter,system-ui,Roboto,Arial;color:var(--text);padding:32px}.wrap{max-width:680px;margin:0 auto}.card{background:var(--card);border-radius:14px;box-shadow:0 10px 30px rgba(2,6,23,0.06);padding:30px;border:1px solid rgba(2,6,23,0.04)}.inner{text-align:center}.logo{max-width:140px;margin:0 auto 12px;display:block}.h1{font-size:20px;margin:6px 0}.lead{color:var(--muted)}.code{display:inline-block;padding:12px 18px;border-radius:10px;background:#f3f6f5;border:1px dashed rgba(15,23,42,0.06);font-weight:800;letter-spacing:3px;font-size:18px;margin-top:12px}.muted{font-size:13px;color:var(--muted)}footer{padding:18px;text-align:center;font-size:13px;color:var(--muted)}@media(max-width:520px){.card{padding:20px}}</style></head><body><div class='wrap'><div class='card' role='article'><div class='inner'><img class='logo' src='<companyLogo>' alt='<companyName> logo'/><h1 class='h1'>Verify your profile update</h1><p class='lead'>Hi <userName>, please confirm your profile update for <strong><companyName></strong> using the OTP below. It expires in <strong><expiryMinutes> minutes</strong>.</p><div class='code'><otpCode></div><p class='muted' style='margin-top:16px'>If you did not request this, you can safely ignore this email.</p><hr style='border:none;border-top:1px solid rgba(2,6,23,0.04);margin:18px 0'/><p style='margin:0;font-size:14px'>Regards,<br/>Support — <companyName></p></div></div><footer>This is an automated message — please do not reply.</footer></div></body></html>"
