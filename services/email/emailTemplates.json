  "html-content": "<!doctype html><html lang='en'><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title>Enrollment confirmation</title><style>:root{--bg:#f8fafc;--card:#ffffff;--accent:#0ea5a3;--muted:#64748b;--text:#0f172a}body{margin:0;background:var(--bg);font-family:Inter,system-ui,Roboto,Arial;color:var(--text);padding:32px}.wrap{max-width:680px;margin:0 auto}.card{background:var(--card);border-radius:16px;box-shadow:0 12px 36px rgba(2,6,23,0.06);padding:28px;border:1px solid rgba(2,6,23,0.04)}.logo{display:block;margin:0 auto 12px;max-width:140px}.h1{text-align:center;font-size:22px;margin-bottom:8px}.lead{color:var(--muted);text-align:center;margin-bottom:12px}.info{background:#fbfdfc;padding:16px;border-radius:12px;border:1px solid rgba(14,165,163,0.06)}.detail{margin:8px 0;color:var(--text);font-size:15px}.muted{font-size:13px;color:var(--muted)}footer{padding:18px;text-align:center;font-size:13px;color:var(--muted)}@media(max-width:520px){.card{padding:20px}}</style></head><body><div class='wrap'><div class='card' role='article'><img class='logo' src='<companyLogo>' alt='<companyName> logo'/><h1 class='h1'>You're enrolled in <courseName></h1><p class='lead'>Hi <userName>, you have been successfully enrolled.</p><div class='info'><p class='detail'><strong>Course:</strong> <courseName></p><p class='detail'><strong>Classroom:</strong> <classroomName></p><p class='detail'><strong>Start date:</strong> <startDate></p></div><p class='muted' style='text-align:center;margin-top:16px'>You can now access your course from your LMS dashboard.</p><hr style='border:none;border-top:1px solid rgba(2,6,23,0.04);margin:22px 0'/><p style='text-align:center;margin:0;font-size:14px'>Learning Team — <companyName></p></div></div><footer>This is an automated message — please do not reply.</footer></body></html>"
},

