[
 {
  "name": "LMS-New-User",
  "subject": "Welcome to <companyName> — Your account is ready",
  "subject-seeding": {
    "companyName": "<companyName>"
  },
  "to": "<userEmail>",
  "html-seeding": {
    "userName": "<userName>",
    "userEmail": "<userEmail>",
    "temporaryPassword": "<temporaryPassword>",
    "companyName": "<companyName>",
    "loginUrl": "<loginUrl>",
    "companyLogo": "<companyLogo>"
  },
  "html-content": "<!doctype html><html lang='en'><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title>Welcome to <companyName></title><style>:root{--bg:#f7fafc;--card:#ffffff;--muted:#64748b;--text:#0f172a;--accent:#0ea5a3;--radius:14px}body{margin:0;background:var(--bg);font-family:Inter,system-ui,-apple-system,'Segoe UI',Roboto,Arial;color:var(--text);padding:32px}.wrap{max-width:680px;margin:0 auto}.card{background:var(--card);border-radius:var(--radius);box-shadow:0 8px 30px rgba(16,24,40,.06);border:1px solid rgba(15,23,42,.04)}.inner{padding:36px}.logo{display:block;margin:0 auto 18px;max-width:140px}.h1{font-size:20px;margin:0 0 8px;font-weight:600}.lead{margin:0 0 18px;color:var(--muted);line-height:1.45}.box{background:#fbfdfc;padding:16px;border-radius:10px;border:1px solid rgba(14,165,163,.08);margin:16px 0}.cred{margin:6px 0;font-weight:600}.btn{display:inline-block;padding:12px 20px;border-radius:12px;text-decoration:none;font-weight:700;background:linear-gradient(90deg,var(--accent),#04b4a0);color:#fff}.muted{font-size:13px;color:var(--muted)}footer{padding:20px;text-align:center;font-size:12px;color:#94a3b8}@media(max-width:520px){.inner{padding:20px}}</style></head><body><div class='wrap'><div class='card'><div class='inner'><img class='logo' src='<companyLogo>' alt='<companyName> logo'/><h1 class='h1'>Welcome, <userName> 👋</h1><p class='lead'>Your account at <strong><companyName></strong> has been created. Use the credentials below to sign in.</p><div class='box'><p class='cred'><strong>Email:</strong> <userEmail></p><p class='cred'><strong>Temporary Password:</strong> <temporaryPassword></p></div><p><a class='btn' href='<loginUrl>'>Sign in to your account</a></p></div><footer>This is an automated message — please do not reply.</footer></div></div></body></html>"
},

{
  "name": "LMS-User-Reset-Password",
  "subject": "Reset your <companyName> account password",
  "subject-seeding": {
    "companyName": "<companyName>"
  },
  "to": "<userEmail>",
  "html-seeding": {
    "userName": "<userName>",
    "resetCode": "<resetCode>",
    "expiryMinutes": "<expiryMinutes>",
    "companyName": "<companyName>",
    "companyLogo": "<companyLogo>"
  },
  "html-content": "<!doctype html><html lang='en'><head><meta charset='utf-8'/><meta name='viewport' content='width=device-width,initial-scale=1'/><title>Password reset</title><style>:root{--bg:#f7fafc;--card:#ffffff;--muted:#6b7280;--text:#0f172a;--accent:#0ea5a3}body{margin:0;background:var(--bg);font-family:Inter,system-ui,Roboto,Arial;color:var(--text);padding:32px}.wrap{max-width:680px;margin:0 auto}.card{background:var(--card);border-radius:14px;box-shadow:0 10px 30px rgba(2,6,23,.06);border:1px solid rgba(2,6,23,.04)}.inner{padding:34px;text-align:center}.logo{max-width:140px;margin:0 auto 14px;display:block}.h1{font-size:22px;margin:8px 0;font-weight:700}.lead{color:var(--muted);margin:8px 0 16px}.code{display:inline-block;padding:12px 18px;border-radius:10px;background:#f3f6f5;border:1px dashed rgba(15,23,42,.06);font-weight:800;letter-spacing:4px;font-size:18px}.muted{font-size:13px;color:var(--muted)}@media(max-width:520px){.inner{padding:20px}}</style></head><body><div class='wrap'><div class='card'><div class='inner'><img class='logo' src='<companyLogo>' alt='<companyName> logo'/><h1 class='h1'>Reset your password</h1><p class='lead'>Hi <userName>, use the code below to reset your <strong><companyName></strong> password. This code expires in <strong><expiryMinutes> minutes</strong>.</p><div class='code'><resetCode></div><p class='muted' style='margin-top:18px'>If you didn’t request this, you can safely ignore this email.</p></div></div></div></body></html>"
},

 {
